{
  "name": "onpe-elecciones-api",
  "version": "0.1.0",
  "private": true,
  "description": "API + scraper para los resultados de las Elecciones Generales 2026 publicados por la ONPE (Peru).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "scrape": "tsx src/scripts/scrape.ts",
    "discover": "tsx src/scripts/discover-endpoints.ts",
    "postinstall": "playwright install --with-deps chromium || true"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "next": "^15.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "playwright": "^1.48.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
